generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SHELTER
}

enum AnimalStatus {
  AVAILABLE
  PENDING
  ADOPTED
}

enum AnimalType {
  CAT
  DOG
}

enum AnimalGender {
  MALE
  FEMALE
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                   String    @id @default(uuid())
  name                 String
  email                String    @unique
  passwordHash         String
  phone                String?
  role                 UserRole  @default(USER)
  avatarUrl            String?
  avatarPublicId       String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  applications AdoptionApplication[]

  reminders      CareReminder[]
  likedAnimals   UserLikedAnimal[]
  adoptedAnimals Animal[]          @relation("UserAdoptedAnimals")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shelter {
  id             String    @id @default(uuid())
  name           String
  description    String
  city           String    @default("Невідоме місто")
  address        String
  phone          String
  email          String
  foundationDate DateTime?
  workingHours   String?

  animals Animal[]
  images  ShelterImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShelterImage {
  id       String  @id @default(uuid())
  imageUrl String
  publicId String?

  shelter   Shelter @relation(fields: [shelterId], references: [id], onDelete: Cascade)
  shelterId String
}

model Animal {
  id           String       @id @default(uuid())
  name         String
  type         AnimalType
  gender       AnimalGender
  city         String       @default("Невідоме місто")
  age          Int
  breed        String?
  healthStatus String
  description  String
  status       AnimalStatus @default(AVAILABLE)

  shelter   Shelter? @relation(fields: [shelterId], references: [id], onDelete: SetNull)
  shelterId String?

  adoptedBy   User?   @relation("UserAdoptedAnimals", fields: [adoptedById], references: [id], onDelete: SetNull)
  adoptedById String?

  images       AnimalImage[]
  applications AdoptionApplication[]
  reminders    CareReminder[]
  likedByUsers UserLikedAnimal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([adoptedById])
}

model UserLikedAnimal {
  userId   String
  animalId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, animalId])
  @@index([animalId])
}

model AnimalImage {
  id       String  @id @default(uuid())
  imageUrl String
  publicId String?

  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)
  animalId String
}

model AdoptionApplication {
  id      String            @id @default(uuid())
  message String?
  status  ApplicationStatus @default(PENDING)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)
  animalId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CareReminder {
  id           String         @id @default(uuid())
  title        String
  description  String?
  reminderDate DateTime
  status       ReminderStatus @default(PENDING)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  animalId String?
  animal   Animal? @relation(fields: [animalId], references: [id])

  createdAt DateTime @default(now())
}

enum ReminderStatus {
  PENDING
  DONE
}

model Article {
  id            String   @id @default(uuid())
  title         String
  content       String
  imageUrl      String?
  imagePublicId String?
  createdAt     DateTime @default(now())
}
